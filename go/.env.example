# Travel Coordinates Backend Environment Variables
# Copy this file to .env and fill in your values

# MySQL
MYSQL_DSN=travel:travel123@tcp(127.0.0.1:3306)/travel_coordinates?parseTime=true&charset=utf8mb4

# Redis
REDIS_ADDR=127.0.0.1:6379

# JWT (change this to a random string)
JWT_SECRET=change-me-in-production

# Alibaba Cloud SMS
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=云渚科技验证服务
SMS_TEMPLATE_CODE=100001

# Cloudflare R2 (optional)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=
